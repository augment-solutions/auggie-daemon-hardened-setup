# Install as /etc/augment-gce/config.env, owned by root and mode 0644 or stricter.
# Both image references must be immutable. Never put registry passwords or tokens here.
POOL_ID=pool-00000000-0000-0000-0000-000000000000
SECRET_PROJECT_ID=replace-with-secret-project-id
SESSION_SECRET_ID=replace-with-secret-id
SESSION_SECRET_VERSION=latest
RUNTIME_IMAGE=region-docker.pkg.dev/project/repository/rocky8-runtime@sha256:replace-with-64-hex-digest
BOOTSTRAP_IMAGE=region-docker.pkg.dev/project/repository/image@sha256:replace-with-64-hex-digest
MAX_AGENTS=4
MEMORY_LIMIT=6g
CPU_LIMIT=2
PIDS_LIMIT=512
# DAEMON_NAME=optional-static-name